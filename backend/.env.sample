# ---- Server ----
PORT=8000

# Where the React frontend runs (used by CORS to allow requests)
CORS_ORIGIN=http://localhost:5173

# ---- Database ----
# Local MongoDB:  mongodb://127.0.0.1:27017
# OR MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net
MONGODB_URI=

# ---- JWT auth ----
# Two separate tokens: a short-lived access token + a long-lived refresh token.
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=10d

# ---- Cloudinary (image hosting) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Admin seed (used by: npm run seed:admin) ----
# Admins are not created via public signup; set these then run the seed script.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@auction.local
ADMIN_PASSWORD=
